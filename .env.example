# Server
PORT=3000
NODE_ENV=production

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=shiry_kids
DB_USER=root
DB_PASS=your_password

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# App
APP_URL=https://back.shirykids.com
ADMIN_URL=https://admin.shirykids.com
CLIENT_URL=shirykidsfun://
LANDING_URL=https://shirykids.com

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Default admin (for first seed)
SEED_ADMIN_EMAIL=admin@shirykids.com
SEED_ADMIN_PASSWORD=Admin@123

# Firebase (push notifications) — path to the service account JSON downloaded
# from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Mailgun (transactional email — password reset, order confirmation, coupon QR codes)
# Get these from https://app.mailgun.com/ — NEVER commit the real API key.
MAILGUN_API_KEY=your_mailgun_sending_key_here
MAILGUN_DOMAIN=mg.shirykids.com
MAILGUN_FROM_EMAIL=no-reply@mg.shirykids.com
MAILGUN_FROM_NAME=Shiry Kids
